# Inworld TTS credentials
INWORLD_API_KEY=your_inworld_api_key_here
INWORLD_VOICE_ID=your_hinglish_voice_id_here
INWORLD_BASE_URL=https://api.inworld.ai/tts/v1

# Optional: OpenAI for script polish (leave blank to use template-only mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Render settings (override defaults in config/settings.py)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
TARGET_DURATION_SECONDS=45
